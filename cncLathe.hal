#sudo apt install python3-gpiozero
#pinout
#
#sudo apt-get install git-core
#sudo git clone https://github.com/WiringPi/WiringPi
#cd WiringPi/
#sudo ./build
#gpio readall


# we need a dir mask and an exclude mask
#

# These correspond to the physical pin on the 40pin header
# for directioin, 1=output, 0=input
# for enable, 0=enable, 1=disable
#pin03: 0x01		//1
#pin05: 0x02		//2
#pin07: 0x04		//4
#pin08: 0x1000		//4096
#pin10: 0x2000		//8192
#pin11: 0x8000		//32768
#pin12: 0x10000		//65536
#pin13: 0x2000000	//33554432
#pin15: 0x100000	//1048576
#pin16: 0x200000	//2097152
#pin18: 0x400000	//4194304
#pin19: 0x100		//256
#pin21: 0x80  		//128
#pin22: 0x800000	//8388608
#pin23: 0x200		//512
#pin24: 0x40  		//64
#pin26: 0x20  		//32
#pin29: 0x08		//8
#pin31: 0x10  		//16
#pin32: 0x400		//1024
#pin33: 0x800		//2048
#pin35: 0x20000		//131072
#pin36: 0x4000		//16384
#pin37: 0x1000000	//16777216
#pin38: 0x40000		//262144
#pin40: 0x80000		//524288

loadrt hal_pi_gpio dir=58717087 exclude=0 


# LATHE MODIFICATION: Only 2 stepgens needed (X and Z axes only)
# Lathes typically only need X (cross-slide) and Z (longitudinal) axes
loadrt stepgen step_type=0,0

addf stepgen.make-pulses base-thread
loadrt sum2 count=1
loadrt not count=1

addf stepgen.capture-position servo-thread
addf motion-command-handler servo-thread
addf motion-controller servo-thread
addf stepgen.update-freq servo-thread
addf hal_pi_gpio.read base-thread
addf hal_pi_gpio.write base-thread

#addf pwmgen.update servo-thread
#addf pwmgen.make-pulses base-thread

##############################################
#                Spindle Outputs
##############################################

# LATHE MODIFICATION: Simple relay control for spindle on/off
# Pin 18 controls the relay on the breakout board for spindle motor
# No speed control - just basic on/off functionality
net spindle-enable spindle.0.on => hal_pi_gpio.pin-18-out

# LATHE MODIFICATION: All advanced spindle controls disabled for simplicity
# PWM control (commented out - not needed for basic relay control)
#loadrt pwmgen output_type=0
#addf pwmgen.update servo-thread
#addf pwmgen.make-pulses base-thread
#net spindle-speed-cmd spindle.0.speed-out => pwmgen.0.value
#net spindle-on spindle.0.on => pwmgen.0.enable  
#net spindle-pwm pwmgen.0.pwm => hal_pi_gpio.pin-12-out
#setp pwmgen.0.scale 1800

