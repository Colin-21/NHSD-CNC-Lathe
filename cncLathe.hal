##############################################
#                Stepper Outputs
##############################################

# Attention - Pin Numbers are RPI physical pin Numbers
# not GPIO Numbers or BCM numbers
# Connect these pins to your DM8078 stepper drivers:

# X-AXIS (Cross-slide): Moves tool toward/away from workpiece centerline
net xenable => hal_pi_gpio.pin-37-out    # Enable signal to both drivers
net xstep	=> hal_pi_gpio.pin-21-out     # X-axis step pulses (original pin from document)
net xdir	=> hal_pi_gpio.pin-19-out     # X-axis direction (original pin from document)

# Y-AXIS: Removed for lathe (not needed - workpiece rotates instead)
# Original pins were pin-23 and pin-29, now available for other uses
#net ystep	=> hal_pi_gpio.pin-23-out
#net ydir	=> hal_pi_gpio.pin-29-out

# Z-AXIS (Longitudinal): Moves tool along length of workpiece  
net zstep	=> hal_pi_gpio.pin-31-out     # Z-axis step pulses (original pin from document)
net zdir	=> hal_pi_gpio.pin-35-out     # Z-axis direction (original pin from document)

# A-AXIS: Available for future expansion (4th axis, indexer, etc.)
#net astep	=> hal_pi_gpio.pin-11-out
#net adir	=> hal_pi_gpio.pin-16-out

# B-AXIS: Removed (pin 18 now used for spindle relay)
#net bstep	=> hal_pi_gpio.pin-13-out 
#net bdir	=> hal_pi_gpio.pin-18-out   # Now used for spindle relay control

##############################################
#               General Outputs
##############################################

# Pin 18 is now dedicated to spindle relay control
# Other pins available for coolant, tool changer, etc.
# Example coolant connection (uncomment if needed):
#net coolant iocontrol.0.coolant-flood => hal_pi_gpio.pin-12-out

##############################################
#		Limit/Home Inputs - ALL DISABLED
##############################################

# SAFETY WARNING: No limit switches or e-stop configured!
# This configuration is for testing and manual operation only
# Operator must manually prevent crashes and over-travel

# All limit switch inputs commented out for simplified setup
#net min-home-x	<= hal_pi_gpio.pin-26-in  # X-axis home/limit 
#net min-home-z	<= hal_pi_gpio.pin-33-in  # Z-axis home/limit
#net all-limit   <= hal_pi_gpio.pin-24-in  # Common limit switch
#net estop-in    <= hal_pi_gpio.pin-22-in  # Emergency stop

# Home switch connections (all disabled)
#net X-home hal_pi_gpio.pin-26-in => joint.0.home-sw-in joint.0.neg-lim-sw-in
#net Z-home hal_pi_gpio.pin-33-in => joint.1.home-sw-in joint.1.neg-lim-sw-in

##############################################
#			Stepper Configuration
##############################################

# X-AXIS CONFIGURATION (Cross-slide movement)
# This axis moves the tool toward and away from the workpiece centerline
setp stepgen.0.position-scale [JOINT_0]SCALE
setp stepgen.0.steplen 1
setp stepgen.0.stepspace 0
setp stepgen.0.dirhold 60000
setp stepgen.0.dirsetup 60000
setp stepgen.0.maxaccel [JOINT_0]STEPGEN_MAXACCEL
net xpos-cmd joint.0.motor-pos-cmd => stepgen.0.position-cmd
net xpos-fb stepgen.0.position-fb => joint.0.motor-pos-fb
net xstep <= stepgen.0.step
net xdir <= stepgen.0.dir
net xenable joint.0.amp-enable-out => stepgen.0.enable

# NO LIMIT SWITCHES: All limit/home connections removed for X-axis
#net min-home-x => joint.0.home-sw-in
#net all-limit => joint.0.neg-lim-sw-in
#net all-limit => joint.0.pos-lim-sw-in

# Y-AXIS CONFIGURATION: Completely removed for lathe
# Original mill Y-axis moved workpiece front/back - not needed for lathe
#setp stepgen.1.position-scale [JOINT_1]SCALE
#setp stepgen.1.steplen 1
#setp stepgen.1.stepspace 0
#setp stepgen.1.dirhold 60000
#setp stepgen.1.dirsetup 60000
#setp stepgen.1.maxaccel [JOINT_1]STEPGEN_MAXACCEL
#net ypos-cmd joint.1.motor-pos-cmd => stepgen.1.position-cmd
#net ypos-fb stepgen.1.position-fb => joint.1.motor-pos-fb
#net ystep <= stepgen.1.step
#net ydir <= stepgen.1.dir
#net yenable joint.1.amp-enable-out => stepgen.1.enable
#net min-home-y => joint.1.home-sw-in
#net all-limit => joint.1.neg-lim-sw-in
#net all-limit => joint.1.pos-lim-sw-in

# Z-AXIS CONFIGURATION (Longitudinal movement)
# This axis moves the tool along the length of the workpiece
setp stepgen.1.position-scale [JOINT_1]SCALE
setp stepgen.1.steplen 1
setp stepgen.1.stepspace 0
setp stepgen.1.dirhold 60000
setp stepgen.1.dirsetup 60000
setp stepgen.1.maxaccel [JOINT_1]STEPGEN_MAXACCEL
net zpos-cmd joint.1.motor-pos-cmd => stepgen.1.position-cmd
net zpos-fb stepgen.1.position-fb => joint.1.motor-pos-fb
net zstep <= stepgen.1.step
net zdir <= stepgen.1.dir
net zenable joint.1.amp-enable-out => stepgen.1.enable

# NO LIMIT SWITCHES: All limit/home connections removed for Z-axis
#net min-home-z => joint.1.home-sw-in
#net all-limit => joint.1.neg-lim-sw-in
#net all-limit => joint.1.pos-lim-sw-in

##############################################
#              E-Stop Configuration
##############################################

# SIMPLIFIED E-STOP: No physical e-stop switch connected
# This creates a software-only e-stop that's always enabled
# WARNING: This is for testing only - add physical e-stop for production use!

net estop-out <= iocontrol.0.user-enable-out
net estop-out => iocontrol.0.emc-enable-in

# For physical e-stop, uncomment these lines and connect switch to pin 22:
#net estop-ext <= hal_pi_gpio.pin-22-in
#net estop-ext => iocontrol.0.emc-enable-in

##############################################
#              Tool Change
##############################################

# Manual tool change configuration (no automatic tool changer)
loadusr -W hal_manualtoolchange
net tool-change iocontrol.0.tool-change => hal_manualtoolchange.change
net tool-changed iocontrol.0.tool-changed <= hal_manualtoolchange.changed
net tool-number iocontrol.0.tool-prep-number => hal_manualtoolchange.number
net tool-prepare-loopback iocontrol.0.tool-prepare => iocontrol.0.tool-prepared

##############################################
#              SAFETY NOTES
##############################################

# WARNING: This configuration has NO safety limits!
# - No limit switches to prevent crashes
# - No home switches for accurate positioning  
# - Software e-stop only (no physical emergency stop)
#
# This setup is suitable for:
# - Initial testing and calibration
# - Manual jogging and setup
# - Learning LinuxCNC operation
#
# Before production use, ADD:
# - Physical limit switches on both axes
# - Physical emergency stop button
# - Proper home switches for repeatability
# - Spindle encoder for threading (if needed)

##############################################
#              Pin Summary for Wiring
##############################################

# Connect these Raspberry Pi pins to your system:
# 
# STEPPER DRIVERS (DM8078):
# Pin 37 -> Enable (both X and Z drivers)
# Pin 21 -> X-Step (X-axis driver PUL+)
# Pin 19 -> X-Dir  (X-axis driver DIR+)  
# Pin 31 -> Z-Step (Z-axis driver PUL+)
# Pin 35 -> Z-Dir  (Z-axis driver DIR+)
# GND    -> All PUL-, DIR-, ENA- connections
#
# SPINDLE CONTROL:
# Pin 18 -> Spindle relay control
#
# AVAILABLE PINS FOR FUTURE USE:
# Pin 12 -> Available (could be coolant)
# Pin 23, 29 -> Available (were Y-axis step/dir)
# Pin 11, 16 -> Available (could be A-axis)
# Pin 22, 24, 26, 33 -> Available (could be limits/e-stop)