###### Enable (tested)
#net spindle-enable spindle.0.on => hal_pi_gpio.pin-18-out

# LATHE CHANGE 7: Phenix lathe has 3 mechanical speed ranges toggled
#                 externally (outside LinuxCNC). No PWM speed control needed.
#                 The spindle on/off relay is wired to pin-18 (breakout DB25 pin 17).
#                 LinuxCNC sends spindle-on when M3/M4 is commanded, which drives
#                 the relay for motor contactor control if wired.
#                 Comment out spindle-on line below if no relay contactor is used.
#
# --- ROUTER ORIGINAL PWM spindle block (commented out for lathe) ---
#loadrt pwmgen output_type=0                                        # ROUTER: PWM spindle speed control
#addf pwmgen.update servo-thread                                    # ROUTER: PWM update thread
#addf pwmgen.make-pulses base-thread                                # ROUTER: PWM pulse thread
#net spindle-speed-cmd spindle.0.speed-out => pwmgen.0.value       # ROUTER: speed command to PWM
#net spindle-on spindle.0.on => pwmgen.0.enable                    # ROUTER: spindle enable to PWM
#net spindle-pwm pwmgen.0.pwm => hal_pi_gpio.pin-12-out            # ROUTER: PWM out on pin 12
#setp pwmgen.0.scale 1800                                          # ROUTER: max RPM scale value
# --- End router PWM block ---

# LATHE: Spindle on/off only via relay (DB25 pin 17 = Pi pin 18).
#        Speed is controlled by external 3-position mechanical selector on the lathe.
net spindle-on spindle.0.on => hal_pi_gpio.pin-18-out


