##############################################
#                Stepper Outputs
##############################################

#Attention - Pin Numbers are RPI physical pin Numbers
#not GPIO Numbers or BCM numbers
#if the pin or direction do not exist, change the 
#loadrt hal_pi_gpio statement above to have the correct values

#net xenable not.1.in
#net x-not-enable not.1.out => hal_pi_gpio.pin-37-out

#setp hal_pi_gpio.pin-37-out-invert true

net xenable => hal_pi_gpio.pin-37-out

# X axis - cross slide (unchanged from router)
net xstep	=> hal_pi_gpio.pin-21-out 
net xdir	=> hal_pi_gpio.pin-19-out

# LATHE CHANGE 2: Y axis has no physical meaning on a lathe (no Y carriage).
#                 Pins 23 and 29 left unwired on breakout board.
#net ystep	=> hal_pi_gpio.pin-23-out   # ROUTER ORIGINAL: Y axis step - not used on lathe
#net ydir	=> hal_pi_gpio.pin-29-out   # ROUTER ORIGINAL: Y axis dir  - not used on lathe

# Z axis - carriage along bed (physical pins unchanged, only joint number changes below)
net zstep	=> hal_pi_gpio.pin-31-out
net zdir	=> hal_pi_gpio.pin-35-out

# LATHE CHANGE 6: A and B axes not used on a 2-axis lathe.
#net astep	=> hal_pi_gpio.pin-11-out   # ROUTER ORIGINAL: A axis step - not used on lathe
#net adir	=> hal_pi_gpio.pin-16-out   # ROUTER ORIGINAL: A axis dir  - not used on lathe
#net bstep	=> hal_pi_gpio.pin-13-out   # ROUTER ORIGINAL: B axis step - not used on lathe
#net bdir	=> hal_pi_gpio.pin-18-out   # ROUTER ORIGINAL: B axis dir / shared relay - not used on lathe



##############################################
#               General Outputs
##############################################
#pin 18 controls the relay on the breakout board, so it can
#be used for the coolant if it isn't already used for 
#axis B or the spindle on/off
#
#net coolant iocontrol.0.coolant-flood => hal_pi_gpio.pin-18-out
#

##############################################
#			Limit Inputs
##############################################
net min-home-x	<= hal_pi_gpio.pin-26-in
# LATHE CHANGE 4: No Y axis on lathe - Y home/limit input removed.
#net min-home-y	<= hal_pi_gpio.pin-32-in   # ROUTER ORIGINAL: Y home switch - not used on lathe
net min-home-z	<= hal_pi_gpio.pin-33-in
# LATHE CHANGE 8: No physical limit switches on this lathe. Soft limits are
#                 used instead, defined by MIN_LIMIT/MAX_LIMIT in the INI file.
#                 Pin-24 (all-limit) is disconnected and the net removed.
#net all-limit   <= hal_pi_gpio.pin-24-in   # ROUTER ORIGINAL: hardware limit input - no limits on lathe
#pin 22 is the eSTOP

#net X-home hal_pi_gpio.pin-22-in => axis.0.home-sw-in axis.0.neg-lim-sw-in
#net Y-home hal_pi_gpio.pin-24-in => axis.1.home-sw-in axis.1.neg-lim-sw-in
#net Z-home hal_pi_gpio.pin-26-in => axis.2.home-sw-in axis.2.neg-lim-sw-in

# connect pin 32 to all three max limits
# net XYZ-max-lim hal_pi_gpio.pin-32-in => axis.0.pos-lim-sw-in 
# axis.1.pos-lim-sw-in axis.2.pos-lim-sw-in



##############################################
#			Stepper params
##############################################

# --- JOINT 0: X axis (cross slide) - unchanged from router ---
setp stepgen.0.position-scale [JOINT_0]SCALE
setp stepgen.0.steplen 1
setp stepgen.0.stepspace 0
setp stepgen.0.dirhold 60000
setp stepgen.0.dirsetup 60000
setp stepgen.0.maxaccel [JOINT_0]STEPGEN_MAXACCEL
net xpos-cmd joint.0.motor-pos-cmd => stepgen.0.position-cmd
net xpos-fb stepgen.0.position-fb => joint.0.motor-pos-fb
net xstep <= stepgen.0.step
net xdir <= stepgen.0.dir
net xenable joint.0.amp-enable-out => stepgen.0.enable
net min-home-x => joint.0.home-sw-in
# LATHE CHANGE 8: No hardware limits - neg/pos limit switch inputs removed.
#                 Soft limits set in INI [JOINT_0] MIN_LIMIT / MAX_LIMIT.
#net all-limit => joint.0.neg-lim-sw-in   # ROUTER ORIGINAL: hardware limit - not used on lathe
#net all-limit => joint.0.pos-lim-sw-in   # ROUTER ORIGINAL: hardware limit - not used on lathe


# LATHE CHANGE 3: Y axis joint block removed.
#                 On the router, joint.1 was Y. On the lathe, joint.1 is now Z.
# --- ROUTER ORIGINAL Y axis block (joint.1 / stepgen.1) ---
#setp stepgen.1.position-scale [JOINT_1]SCALE          # ROUTER ORIGINAL: Y axis scale
#setp stepgen.1.steplen 1                               # ROUTER ORIGINAL: Y axis steplen
#setp stepgen.1.stepspace 0                             # ROUTER ORIGINAL: Y axis stepspace
#setp stepgen.1.dirhold 60000                           # ROUTER ORIGINAL: Y axis dirhold
#setp stepgen.1.dirsetup 60000                          # ROUTER ORIGINAL: Y axis dirsetup
#setp stepgen.1.maxaccel [JOINT_1]STEPGEN_MAXACCEL      # ROUTER ORIGINAL: Y axis max accel
#net ypos-cmd joint.1.motor-pos-cmd => stepgen.1.position-cmd  # ROUTER ORIGINAL: Y pos cmd
#net ypos-fb  stepgen.1.position-fb => joint.1.motor-pos-fb    # ROUTER ORIGINAL: Y pos feedback
#net ystep    <= stepgen.1.step                         # ROUTER ORIGINAL: Y step signal
#net ydir     <= stepgen.1.dir                          # ROUTER ORIGINAL: Y dir signal
#net yenable  joint.1.amp-enable-out => stepgen.1.enable       # ROUTER ORIGINAL: Y enable
#net min-home-y => joint.1.home-sw-in                  # ROUTER ORIGINAL: Y home switch
#net all-limit  => joint.1.neg-lim-sw-in               # ROUTER ORIGINAL: Y neg limit
#net all-limit  => joint.1.pos-lim-sw-in               # ROUTER ORIGINAL: Y pos limit
# --- End router Y axis block ---


# LATHE CHANGE 5: Z axis renumbered from joint.2/stepgen.2 (router) to
#                 joint.1/stepgen.1 (lathe) because Y was removed and LinuxCNC
#                 requires joints to be numbered contiguously from 0.
#                 Physical step/dir pins on the breakout board are unchanged.
# --- ROUTER ORIGINAL Z axis block shown for reference ---
#setp stepgen.2.position-scale [JOINT_2]SCALE              # ROUTER ORIGINAL: was stepgen.2
#setp stepgen.2.steplen 1                                   # ROUTER ORIGINAL
#setp stepgen.2.stepspace 0                                 # ROUTER ORIGINAL
#setp stepgen.2.dirhold 60000                               # ROUTER ORIGINAL
#setp stepgen.2.dirsetup 60000                              # ROUTER ORIGINAL
#setp stepgen.2.maxaccel [JOINT_2]STEPGEN_MAXACCEL          # ROUTER ORIGINAL
#net zpos-cmd joint.2.motor-pos-cmd => stepgen.2.position-cmd  # ROUTER ORIGINAL: was joint.2
#net zpos-fb  stepgen.2.position-fb => joint.2.motor-pos-fb    # ROUTER ORIGINAL: was joint.2
#net zstep    <= stepgen.2.step                             # ROUTER ORIGINAL
#net zdir     <= stepgen.2.dir                              # ROUTER ORIGINAL
#net zenable  joint.2.amp-enable-out => stepgen.2.enable   # ROUTER ORIGINAL: was joint.2
#net min-home-z => joint.2.home-sw-in                      # ROUTER ORIGINAL: was joint.2
#net all-limit  => joint.2.neg-lim-sw-in                   # ROUTER ORIGINAL: was joint.2 - hardware limit
#net all-limit  => joint.2.pos-lim-sw-in                   # ROUTER ORIGINAL: was joint.2 - hardware limit
# --- End router Z axis block ---

# --- JOINT 1: Z axis (carriage along bed) - renumbered from joint.2 to joint.1 ---
setp stepgen.1.position-scale [JOINT_1]SCALE
setp stepgen.1.steplen 1
setp stepgen.1.stepspace 0
setp stepgen.1.dirhold 60000
setp stepgen.1.dirsetup 60000
setp stepgen.1.maxaccel [JOINT_1]STEPGEN_MAXACCEL
net zpos-cmd joint.1.motor-pos-cmd => stepgen.1.position-cmd
net zpos-fb stepgen.1.position-fb => joint.1.motor-pos-fb
net zstep <= stepgen.1.step
net zdir <= stepgen.1.dir
net zenable joint.1.amp-enable-out => stepgen.1.enable
net min-home-z => joint.1.home-sw-in
# LATHE CHANGE 8: No hardware limits - neg/pos limit switch inputs removed.
#                 Soft limits set in INI [JOINT_1] MIN_LIMIT / MAX_LIMIT.
#net all-limit => joint.1.neg-lim-sw-in   # ROUTER ORIGINAL: hardware limit - not used on lathe
#net all-limit => joint.1.pos-lim-sw-in   # ROUTER ORIGINAL: hardware limit - not used on lathe

net estop-out <= iocontrol.0.user-enable-out
#customer note: use estop-ext instead of estop-out in the next statement
net estop-ext => iocontrol.0.emc-enable-in
#net estop-out => iocontrol.0.emc-enable-in

loadusr -W hal_manualtoolchange
net tool-change iocontrol.0.tool-change => hal_manualtoolchange.change
net tool-changed iocontrol.0.tool-changed <= hal_manualtoolchange.changed
net tool-number iocontrol.0.tool-prep-number => hal_manualtoolchange.number
net tool-prepare-loopback iocontrol.0.tool-prepare => iocontrol.0.tool-prepared
